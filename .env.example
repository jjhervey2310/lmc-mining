# ============================================================
# LMC Mining MVP — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# CoinGecko API (free tier available at coingecko.com/en/api)
COINGECKO_API_KEY=your_coingecko_api_key

# Spreadsheet link delivered in welcome email (Email 1)
# [OWNER ACTION: Create a Google Sheet with your mining ROI model, share with "Anyone with the link can view", paste the URL here]
# [OWNER ACTION: Add SPREADSHEET_LINK to Vercel Environment Variables]
SPREADSHEET_LINK=https://docs.google.com/spreadsheets/d/your_sheet_id_here/edit?usp=sharing

# Resend (transactional email — resend.com)
# [OWNER ACTION: Get free API key from resend.com — free tier = 3,000 emails/month]
# Add RESEND_API_KEY to Vercel Environment Variables (Settings → Environment Variables)
RESEND_API_KEY=your_resend_api_key_here
NOTIFICATION_EMAIL=your@email.com

# Stripe payment links (create in Stripe Dashboard)
# These are exposed to the browser — they are public payment page links, not secret keys
STRIPE_97_AUDIT_URL=https://buy.stripe.com/your_97_audit_link
STRIPE_297_AUDIT_URL=https://buy.stripe.com/your_297_audit_link
NEXT_PUBLIC_STRIPE_97_URL=https://buy.stripe.com/your_97_audit_link
NEXT_PUBLIC_STRIPE_297_URL=https://buy.stripe.com/your_297_audit_link

# Email list (Mailchimp or ConvertKit embeddable form URL)
MAILCHIMP_OR_CONVERTKIT_FORM_URL=https://your-email-service.com/form/embed
NEXT_PUBLIC_EMAIL_FORM_URL=https://your-email-service.com/form/embed

# Abundant Miners affiliate
ABUNDANT_MINERS_AFFILIATE_URL=https://abundantminers.com/?ref=your_affiliate_id
ABUNDANT_MINERS_MONTHLY_FEE_AIR=225
ABUNDANT_MINERS_DEPOSIT=500

# Analytics — leave blank to disable (site currently has no working analytics)
# [OWNER ACTION: create a GA4 property at analytics.google.com, copy the Measurement ID]
NEXT_PUBLIC_GA_MEASUREMENT_ID=your_ga4_measurement_id
# [OWNER ACTION: create a project at clarity.microsoft.com, copy the Project ID]
NEXT_PUBLIC_CLARITY_PROJECT_ID=your_clarity_project_id
