<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.lightningmines.contentchain</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>/Users/jacobslaptop/.lightningmines/daily-content-chain.sh</string>
  </array>
  <!-- 6:45am local — before the 9am ET X slot, after the midnight UTC snapshot. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>6</integer>
    <key>Minute</key>
    <integer>45</integer>
  </dict>
  <!-- If the Mac was asleep at 6:45, run on wake. -->
  <key>RunAtLoad</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/tmp/lmc-contentchain.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/lmc-contentchain.err</string>
</dict>
</plist>
